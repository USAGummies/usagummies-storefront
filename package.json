{
  "name": "usagummies-storefront",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "PORT=4000 next dev -H 127.0.0.1 -p 4000",
    "dev:clean": "rm -rf .next .next/cache .turbo node_modules/.cache && npm run dev",
    "prebuild": "node scripts/check-seo-meta.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "node scripts/lint-with-cache.mjs",
    "breadcrumbs:check": "node scripts/check-breadcrumbs.mjs",
    "seo:check": "node scripts/check-seo-meta.mjs",
    "verify:env": "node scripts/verify-env.mjs",
    "verify:net": "node scripts/verify-network.mjs",
    "verify:production-smoke": "node scripts/production-smoke.mjs",
    "audit:prod-readiness": "node scripts/production-readiness-audit.mjs",
    "release:gate": "node scripts/verify-production-release.mjs",
    "screenshots": "playwright test tests/screenshots.spec.ts",
    "playwright:install": "playwright install",
    "gmail:auth": "node scripts/gmail.mjs auth",
    "gmail:list": "node scripts/gmail.mjs list",
    "gmail:send": "node scripts/gmail.mjs send",
    "agentic:init": "node scripts/usa-gummies-agentic.mjs init",
    "agentic:status": "node scripts/usa-gummies-agentic.mjs status",
    "agentic:params": "node scripts/usa-gummies-agentic.mjs params",
    "agentic:traction": "node scripts/usa-gummies-agentic.mjs traction",
    "agentic:audit": "node scripts/usa-gummies-agentic.mjs run-agent audit",
    "agentic:learn": "node scripts/usa-gummies-agentic.mjs run-agent agent8",
    "agentic:bounce-intel": "node scripts/usa-gummies-agentic.mjs run-agent agent9",
    "agentic:forecast": "node scripts/usa-gummies-agentic.mjs run-agent agent11",
    "agentic:verify-contacts": "node scripts/usa-gummies-agentic.mjs run-agent agent12",
    "agentic:quota-enforcer": "node scripts/usa-gummies-agentic.mjs run-agent agent13",
    "agentic:no-resend-guard": "node scripts/usa-gummies-agentic.mjs run-agent agent18 --limit 600",
    "agentic:kpi-governor": "node scripts/usa-gummies-agentic.mjs run-agent agent16",
    "agentic:deliverability-sre": "node scripts/usa-gummies-agentic.mjs run-agent agent17",
    "agentic:self-heal": "node scripts/usa-gummies-agentic.mjs run-agent agent10",
    "agentic:command-center": "echo 'Open http://127.0.0.1:4000/command-center while running npm run dev'",
    "agentic:command-center:ensure": "bash scripts/ensure-agentic-command-center.sh",
    "agentic:dmarc-cleanup": "bash scripts/dmarc-cleanup.sh",
    "agentic:run-daily": "node scripts/usa-gummies-agentic.mjs run-daily",
    "agentic:research-backfill": "node scripts/usa-gummies-agentic.mjs run-research-backfill --target 20 --limit 6 --source manual-backfill",
    "agentic:run-agent": "node scripts/usa-gummies-agentic.mjs run-agent",
    "agentic:install-schedule": "bash scripts/install-usa-gummies-agentic-cron.sh"
  },
  "dependencies": {
    "@ai-sdk/openai": "^1.3.24",
    "@ai-sdk/react": "^1.2.12",
    "@auth/core": "^0.41.0",
    "@mdx-js/react": "^3.1.1",
    "@types/bcryptjs": "^2.4.6",
    "@upstash/qstash": "^2.9.0",
    "@vercel/analytics": "^1.6.1",
    "@vercel/kv": "^3.0.0",
    "@vercel/speed-insights": "^1.3.1",
    "ai": "^4.3.19",
    "bcryptjs": "^3.0.3",
    "googleapis": "^171.4.0",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.575.0",
    "next": "15.1.11",
    "next-auth": "^5.0.0-beta.30",
    "next-mdx-remote": "^6.0.0",
    "nodemailer": "^7.0.12",
    "openai": "^6.17.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-plaid-link": "^4.1.1",
    "reading-time": "^1.5.0",
    "recharts": "^3.7.0",
    "server-only": "^0.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.4",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.23",
    "eslint": "^9",
    "eslint-config-next": "15.1.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
